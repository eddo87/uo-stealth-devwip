o);\n}\n\nfn main() {\n    // Calling the method is still fine, as i32 implements Debug.\n    some_func(5i32);\n\n    // This would fail to compile now:\n    // struct WithoutDebug;\n    // some_func(WithoutDebug);\n}\n```\n\nRust only looks at the signature of the called function, as such it must\nalready specify all requirements that will be used for every type parameter.\n"},"level":"error","spans":[{"file_name":"C:\\Users\\EdoardoCiccarelli\\.cargo\\registry\\src\\index.crates.io-1949cf8c6b5b557f\\detour-0.8.1\\src\\detours\\statik.rs","byte_start":4666,"byte_end":4800,"line_start":180,"line_end":182,"column_start":5,"column_end":43,"is_primary":true,"text":[{"text":"    unsafe { self.closure.load(Ordering::SeqCst).as_ref() }","highlight_start":5,"highlight_end":60},{"text":"      .ok_or(Error::NotInitialized)","highlight_start":1,"highlight_end":36},{"text":"      .expect(\"retrieving detour closure\")","highlight_start":1,"highlight_end":43}],"label":"the nightly-only, unstable trait `std::marker::Tuple` is not implemented for `<T as Function>::Arguments`","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[{"message":"required for `Box<dyn Fn<<T as Function>::Arguments, Output = <T as Function>::Output>>` to implement `Fn<<T as Function>::Arguments>`","code":null,"level":"note","spans":[],"children":[],"rendered":null},{"message":"required for the cast from `&Box<dyn Fn<<T as Function>::Arguments, Output = <T as Function>::Output>>` to `&dyn Fn<<T as Function>::Arguments, Output = <T as Function>::Output>`","code":null,"level":"note","spans":[],"children":[],"rendered":null},{"message":"consider further restricting the associated type","code":null,"level":"help","spans":[{"file_name":"C:\\Users\\EdoardoCiccarelli\\.cargo\\registry\\src\\index.crates.io-1949cf8c6b5b557f\\detour-0.8.1\\src\\detours\\statik.rs","byte_start":4587,"byte_end":4587,"line_start":178,"line_end":178,"column_start":70,"column_end":70,"is_primary":